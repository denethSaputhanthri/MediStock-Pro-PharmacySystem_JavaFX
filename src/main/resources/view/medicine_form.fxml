<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="764.0" prefWidth="1192.0"
            style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MedicineController">

    <!-- Main BorderPane that fills entire AnchorPane -->
    <BorderPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                style="-fx-background-color: transparent;">

        <!-- ==================== TOP SECTION ==================== -->
        <top>
            <VBox spacing="12" style="-fx-background-color: transparent;">
                <Label text="💊 MEDICINE MANAGEMENT SYSTEM"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI'; -fx-padding: 10 0 0 15;"/>

                <!-- Alert Bar with dynamic message (popup will also be triggered) -->
                <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 10 20;">
                    <Button text="⚠️ CHECK ALERTS" onAction="#checkAlerts"
                            style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);"/>
                    <Button text="🧾 SALES INVOICE" onAction="#showSalesInvoice"
                            style="-fx-background-color: #0891b2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);"/>
                </HBox>
                <Separator style="-fx-background-color: #cbd5e1;"/>
            </VBox>
        </top>

        <!-- ==================== LEFT FORM (Medicine Entry) ==================== -->
        <left>
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-padding: 20;">
                <Label text="📋 MEDICINE DETAILS"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f3b5c; -fx-border-color: #bae6fd; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 8 0;"/>

                <GridPane hgap="15" vgap="12">
                    <padding><Insets top="5" bottom="5"/></padding>

                    <Label text="Medicine Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="nameField" promptText="e.g., Paracetamol" GridPane.rowIndex="0" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Brand:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="brandField" promptText="e.g., GSK" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Expiry Date:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <DatePicker fx:id="expiryDatePicker" promptText="YYYY-MM-DD" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Quantity:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="quantityField" promptText="Stock amount" GridPane.rowIndex="3" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Purchase Price:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="purchasePriceField" promptText="0.00" GridPane.rowIndex="4" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Selling Price:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="sellingPriceField" promptText="0.00" GridPane.rowIndex="5" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                </GridPane>

                <!-- Buttons with Green/Blue Accents -->
                <HBox spacing="15" alignment="CENTER" style="-fx-padding: 15 0 5 0;">
                    <Button text="➕ ADD MEDICINE" onAction="#addMedicine"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);"/>
                    <Button text="✏️ UPDATE" onAction="#updateMedicine"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    <Button text="🗑️ DELETE" onAction="#deleteMedicine"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand;"/>
                </HBox>

                <!-- Extra: Sell / Quick Invoice Button (Blue accent) -->
                <Button text="💰 CREATE SALE INVOICE" onAction="#createSaleInvoice"
                        style="-fx-background-color: #0e7c9e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8; -fx-cursor: hand; -fx-font-size: 13px;"/>
                <Label style="-fx-font-size: 10px; -fx-text-fill: #6c757d; -fx-wrap-text: true;" text="💡 Select a medicine from table then click 'Create Sale Invoice'"/>
            </VBox>
        </left>

        <!-- ==================== CENTER TABLE ==================== -->
        <center>
            <VBox spacing="10" style="-fx-padding: 10 20 10 15;">
                <Label text="📋 INVENTORY LIST"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-padding: 0 0 5 0;"/>
                <TableView fx:id="medicineTable"
                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 2;">
                    <columns>
                        <TableColumn fx:id="nameColumn" text="Medicine Name" prefWidth="180"/>
                        <TableColumn fx:id="brandColumn" text="Brand" prefWidth="130"/>
                        <TableColumn fx:id="expiryColumn" text="Expiry Date" prefWidth="120"/>
                        <TableColumn fx:id="quantityColumn" text="Stock Qty" prefWidth="90"/>
                        <TableColumn fx:id="purchasePriceColumn" text="Purchase Price" prefWidth="110"/>
                        <TableColumn fx:id="sellingPriceColumn" text="Selling Price" prefWidth="110"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                    </columns>

                    <!-- Inline CSS for alternating row colors and hover effect -->
                    <style>
                        .table-row-cell:odd {
                        -fx-background-color: #f1f5f9;
                        }
                        .table-row-cell:even {
                        -fx-background-color: white;
                        }
                        .table-row-cell:hover {
                        -fx-background-color: #e0f2fe;
                        }
                        .table-view .column-header {
                        -fx-background-color: #eef2ff;
                        -fx-font-weight: bold;
                        -fx-border-color: #cbd5e1;
                        -fx-border-width: 0 0 1 0;
                        }
                    </style>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label text="🔴 Red row = Expired or Low Stock (≤ 10 units)"
                           style="-fx-font-size: 11px; -fx-text-fill: #b91c1c; -fx-font-weight: bold; -fx-background-color: #fee2e2; -fx-padding: 4 8; -fx-background-radius: 12;"/>
                </HBox>
            </VBox>
        </center>

        <!-- ==================== BOTTOM STATUS (optional) ==================== -->
        <bottom>
            <HBox style="-fx-background-color: #eef2ff; -fx-padding: 8 20; -fx-border-radius: 12; -fx-background-radius: 12;" spacing="15" alignment="CENTER_LEFT">
                <Label text="✅ Ready" style="-fx-text-fill: #1e4620; -fx-font-size: 12px;"/>
                <Label text="⚡ Low stock threshold: ≤ 10 units" style="-fx-text-fill: #b45309; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="💡 Tip: Double-click row to edit" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
            </HBox>
        </bottom>
    </BorderPane>
</AnchorPane>
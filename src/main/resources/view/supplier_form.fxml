<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="764.0" prefWidth="1192.0"
            style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.SupplierController">

    <BorderPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                style="-fx-background-color: transparent;">

        <!-- ==================== TOP SECTION ==================== -->
        <top>
            <VBox spacing="12" style="-fx-background-color: transparent;">
                <Label text="🏢 SUPPLIER MANAGEMENT SYSTEM"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI'; -fx-padding: 10 0 0 15;"/>

                <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 10 20;">
                    <Button text="📞 CONTACT ALL" onAction="#contactAllSuppliers"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);"/>
                    <Button text="⚠️ CHECK ALERTS" onAction="#checkSupplierAlerts"
                            style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <Separator style="-fx-background-color: #cbd5e1;"/>
            </VBox>
        </top>

        <!-- ==================== LEFT FORM ==================== -->
        <left>
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-padding: 20;">
                <Label text="📝 SUPPLIER DETAILS"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f3b5c; -fx-border-color: #bae6fd; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 8 0;"/>

                <GridPane hgap="15" vgap="12">
                    <padding><Insets top="5" bottom="5"/></padding>

                    <Label text="Supplier Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="nameField" promptText="e.g., Pharma Distributors Ltd." GridPane.rowIndex="0" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Contact Number:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="contactField" promptText="+94 XX XXX XXXX" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextField fx:id="emailField" promptText="supplier@example.com" GridPane.rowIndex="2" GridPane.columnIndex="1"
                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>

                    <Label text="Address:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                    <TextArea fx:id="addressField" promptText="Street, City, Country" GridPane.rowIndex="3" GridPane.columnIndex="1"
                              prefHeight="80" wrapText="true"
                              style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                </GridPane>

                <!-- Buttons with Green/Blue Accents -->
                <HBox spacing="15" alignment="CENTER" style="-fx-padding: 15 0 5 0;">
                    <Button text="➕ ADD SUPPLIER" onAction="#addSupplier"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);"/>
                    <Button text="✏️ UPDATE" onAction="#updateSupplier"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    <Button text="🗑️ DELETE" onAction="#deleteSupplier"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand;"/>
                </HBox>

                <Button text="📧 SEND EMAIL NOTIFICATION" onAction="#sendEmailNotification"
                        style="-fx-background-color: #0891b2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8; -fx-cursor: hand; -fx-font-size: 13px;"/>
                <Label style="-fx-font-size: 10px; -fx-text-fill: #6c757d; -fx-wrap-text: true;" text="💡 Select a supplier from the table then click 'Send Email'."/>
            </VBox>
        </left>

        <!-- ==================== CENTER TABLE ==================== -->
        <center>
            <VBox spacing="10" style="-fx-padding: 10 20 10 15;">
                <Label text="📋 SUPPLIER LIST"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-padding: 0 0 5 0;"/>
                <TableView fx:id="supplierTable"
                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 2;">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="nameColumn" text="Supplier Name" prefWidth="200"/>
                        <TableColumn fx:id="contactColumn" text="Contact Number" prefWidth="130"/>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                        <TableColumn fx:id="addressColumn" text="Address" prefWidth="280"/>
                    </columns>

                    <!-- Inline CSS for alternating row colors and hover effect -->
                    <style>
                        .table-row-cell:odd {
                        -fx-background-color: #f1f5f9;
                        }
                        .table-row-cell:even {
                        -fx-background-color: white;
                        }
                        .table-row-cell:hover {
                        -fx-background-color: #e0f2fe;
                        }
                        .table-view .column-header {
                        -fx-background-color: #eef2ff;
                        -fx-font-weight: bold;
                        -fx-border-color: #cbd5e1;
                        -fx-border-width: 0 0 1 0;
                        }
                    </style>
                </TableView>
            </VBox>
        </center>

        <!-- ==================== BOTTOM STATUS ==================== -->
        <bottom>
            <HBox style="-fx-background-color: #eef2ff; -fx-padding: 8 20; -fx-border-radius: 12; -fx-background-radius: 12;" spacing="15" alignment="CENTER_LEFT">
                <Label text="✅ Ready" style="-fx-text-fill: #1e4620; -fx-font-size: 12px;"/>
                <Label text="📞 Double-click row to edit" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="💡 Tip: Use 'Contact All' to trigger bulk communication" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
            </HBox>
        </bottom>
    </BorderPane>
</AnchorPane>
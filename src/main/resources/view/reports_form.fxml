<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="764.0" prefWidth="1192.0"
            style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ReportController">

    <BorderPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                style="-fx-background-color: transparent;">

        <!-- ==================== TOP SECTION ==================== -->
        <top>
            <VBox spacing="12" style="-fx-background-color: transparent;">
                <Label text="📊 REPORTS AND ANALYTICS"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI'; -fx-padding: 10 0 0 15;"/>

                <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 10 20;">
                    <Button text="📅 CUSTOM RANGE" onAction="#customRangeReport"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);"/>
                    <Button text="📎 EXPORT PDF" onAction="#exportReportPDF"
                            style="-fx-background-color: #0891b2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <Button text="🖨️ PRINT" onAction="#printReport"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <Separator style="-fx-background-color: #cbd5e1;"/>
            </VBox>
        </top>

        <!-- ==================== CENTER: TABPANE ==================== -->
        <center>
            <TabPane style="-fx-background-color: transparent; -fx-tab-min-height: 40px; -fx-tab-max-height: 40px; -fx-padding: 5 0 0 0;">
                <!-- Tab 1: Daily Report -->
                <Tab text="📆 DAILY" closable="false">
                    <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: transparent;">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Select Date:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                            <DatePicker fx:id="dailyDatePicker" promptText="Pick a date"
                                        style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                            <Button text="🔍 LOAD REPORT" onAction="#loadDailyReport"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 15; -fx-cursor: hand;"/>
                        </HBox>
                        <SplitPane dividerPositions="0.5" style="-fx-background-color: transparent;">
                            <VBox spacing="10" style="-fx-padding: 5;">
                                <Label text="Sales Summary" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <TableView fx:id="dailySalesTable"
                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12;">
                                    <columns>
                                        <TableColumn fx:id="dailyInvoiceColumn" text="Invoice ID" prefWidth="80"/>
                                        <TableColumn fx:id="dailyTimeColumn" text="Time" prefWidth="100"/>
                                        <TableColumn fx:id="dailyCustomerColumn" text="Customer" prefWidth="150"/>
                                        <TableColumn fx:id="dailyTotalColumn" text="Total" prefWidth="100"/>
                                    </columns>
                                    <style>
                                        .table-row-cell:odd { -fx-background-color: #f1f5f9; }
                                        .table-row-cell:even { -fx-background-color: white; }
                                        .table-row-cell:hover { -fx-background-color: #e0f2fe; }
                                        .table-view .column-header { -fx-background-color: #eef2ff; -fx-font-weight: bold; }
                                    </style>
                                </TableView>
                            </VBox>
                            <VBox spacing="10" style="-fx-padding: 5;">
                                <Label text="Sales by Hour" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <BarChart fx:id="dailyBarChart" title="Hourly Sales" legendVisible="false">
                                    <xAxis><CategoryAxis label="Hour"/></xAxis>
                                    <yAxis><NumberAxis label="Amount (Rs)"/></yAxis>
                                </BarChart>
                            </VBox>
                        </SplitPane>
                    </VBox>
                </Tab>

                <!-- Tab 2: Weekly Report -->
                <Tab text="📅 WEEKLY" closable="false">
                    <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: transparent;">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Week Starting:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                            <DatePicker fx:id="weeklyStartDatePicker" promptText="Select Monday"
                                        style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                            <Button text="🔍 LOAD REPORT" onAction="#loadWeeklyReport"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 15; -fx-cursor: hand;"/>
                        </HBox>
                        <SplitPane dividerPositions="0.5" style="-fx-background-color: transparent;">
                            <VBox spacing="10" style="-fx-padding: 5;">
                                <Label text="Daily Breakdown" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <TableView fx:id="weeklyBreakdownTable"
                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12;">
                                    <columns>
                                        <TableColumn fx:id="weekDayColumn" text="Day" prefWidth="100"/>
                                        <TableColumn fx:id="weekSalesColumn" text="Total Sales" prefWidth="120"/>
                                        <TableColumn fx:id="weekCountColumn" text="Invoices" prefWidth="100"/>
                                    </columns>
                                    <style>
                                        .table-row-cell:odd { -fx-background-color: #f1f5f9; }
                                        .table-row-cell:even { -fx-background-color: white; }
                                        .table-view .column-header { -fx-background-color: #eef2ff; -fx-font-weight: bold; }
                                    </style>
                                </TableView>
                            </VBox>
                            <VBox spacing="10" style="-fx-padding: 5;">
                                <Label text="Weekly Trend" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <LineChart fx:id="weeklyLineChart" title="Sales Trend (Daily)" legendVisible="false">
                                    <xAxis><CategoryAxis label="Day"/></xAxis>
                                    <yAxis><NumberAxis label="Amount (Rs)"/></yAxis>
                                </LineChart>
                            </VBox>
                        </SplitPane>
                    </VBox>
                </Tab>

                <!-- Tab 3: Monthly Report -->
                <Tab text="📆 MONTHLY" closable="false">
                    <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: transparent;">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Month:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                            <ComboBox fx:id="monthComboBox" promptText="Select Month"
                                      style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                            <Label text="Year:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                            <ComboBox fx:id="yearComboBox" promptText="Select Year"
                                      style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                            <Button text="🔍 LOAD REPORT" onAction="#loadMonthlyReport"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 15; -fx-cursor: hand;"/>
                        </HBox>
                        <SplitPane dividerPositions="0.5" style="-fx-background-color: transparent;">
                            <VBox spacing="10" style="-fx-padding: 5;">
                                <Label text="Daily Summary" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <TableView fx:id="monthlyDailyTable"
                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12;">
                                    <columns>
                                        <TableColumn fx:id="monthDayColumn" text="Day" prefWidth="80"/>
                                        <TableColumn fx:id="monthSalesColumn" text="Total Sales" prefWidth="120"/>
                                        <TableColumn fx:id="monthCountColumn" text="Invoices" prefWidth="100"/>
                                    </columns>
                                    <style>
                                        .table-row-cell:odd { -fx-background-color: #f1f5f9; }
                                        .table-row-cell:even { -fx-background-color: white; }
                                        .table-view .column-header { -fx-background-color: #eef2ff; -fx-font-weight: bold; }
                                    </style>
                                </TableView>
                            </VBox>
                            <VBox spacing="10" style="-fx-padding: 5;">
                                <Label text="Monthly Comparison" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <AreaChart fx:id="monthlyAreaChart" title="Daily Sales" legendVisible="false">
                                    <xAxis><CategoryAxis label="Day of Month"/></xAxis>
                                    <yAxis><NumberAxis label="Amount (Rs)"/></yAxis>
                                </AreaChart>
                            </VBox>
                        </SplitPane>
                    </VBox>
                </Tab>

                <!-- Tab 4: Analytics (Charts) -->
                <Tab text="📈 ANALYTICS" closable="false">
                    <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: transparent;">
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="🔄 REFRESH DATA" onAction="#refreshAnalytics"
                                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 15; -fx-cursor: hand;"/>
                            <Button text="📊 EXPORT CHARTS" onAction="#exportCharts"
                                    style="-fx-background-color: #0891b2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 15; -fx-cursor: hand;"/>
                        </HBox>
                        <SplitPane dividerPositions="0.5" orientation="VERTICAL" style="-fx-background-color: transparent;">
                            <HBox spacing="20" style="-fx-padding: 5;">
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="🏆 Top Selling Medicines" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                    <BarChart fx:id="topMedicinesChart" title="Quantity Sold" legendVisible="false">
                                        <xAxis><CategoryAxis label="Medicine"/></xAxis>
                                        <yAxis><NumberAxis label="Units Sold"/></yAxis>
                                    </BarChart>
                                </VBox>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="💰 Revenue by Category" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                    <PieChart fx:id="categoryPieChart" title="Revenue Distribution" legendVisible="true"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="20" style="-fx-padding: 5;">
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="📈 Monthly Revenue Trend" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                    <LineChart fx:id="monthlyRevenueChart" title="Last 12 Months" legendVisible="false">
                                        <xAxis><CategoryAxis label="Month"/></xAxis>
                                        <yAxis><NumberAxis label="Revenue (Rs)"/></yAxis>
                                    </LineChart>
                                </VBox>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="📦 Stock Turnover Rate" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                    <StackedBarChart fx:id="stockTurnoverChart" title="Top 5 Medicines" legendVisible="true">
                                        <xAxis><CategoryAxis label="Medicine"/></xAxis>
                                        <yAxis><NumberAxis label="Turnover (Units)"/></yAxis>
                                    </StackedBarChart>
                                </VBox>
                            </HBox>
                        </SplitPane>
                    </VBox>
                </Tab>
            </TabPane>
        </center>

        <!-- ==================== BOTTOM STATUS ==================== -->
        <bottom>
            <HBox style="-fx-background-color: #eef2ff; -fx-padding: 8 20; -fx-border-radius: 12; -fx-background-radius: 12;" spacing="15" alignment="CENTER_LEFT">
                <Label text="✅ Ready" style="-fx-text-fill: #1e4620; -fx-font-size: 12px;"/>
                <Label text="💡 Use date pickers to view reports for different periods" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="📊 Data refreshes automatically on load" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
            </HBox>
        </bottom>
    </BorderPane>
</AnchorPane>
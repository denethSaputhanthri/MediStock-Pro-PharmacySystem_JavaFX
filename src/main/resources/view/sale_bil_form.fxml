<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="764.0" prefWidth="1192.0"
            style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.SaleBillController">

    <BorderPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                style="-fx-background-color: transparent;">

        <!-- ==================== TOP SECTION ==================== -->
        <top>
            <VBox spacing="12" style="-fx-background-color: transparent;">
                <Label text="💰 SALES AND BILLING MANAGEMENT"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-font-family: 'Segoe UI'; -fx-padding: 10 0 0 15;"/>

                <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 10 20;">
                    <Button text="⚠️ LOW STOCK ALERT" onAction="#checkLowStock"
                            style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);"/>
                    <Button text="📊 DAILY SALES REPORT" onAction="#showDailyReport"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                </HBox>
                <Separator style="-fx-background-color: #cbd5e1;"/>
            </VBox>
        </top>

        <!-- ==================== CENTER: TABPANE ==================== -->
        <center>
            <TabPane style="-fx-background-color: transparent; -fx-tab-min-height: 40px; -fx-tab-max-height: 40px; -fx-padding: 5 0 0 0;">
                <!-- Tab 1: New Sale -->
                <Tab text="🛒 NEW SALE" closable="false">
                    <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: transparent;">
                        <HBox spacing="20" VBox.vgrow="ALWAYS">
                            <!-- Left: Customer & Product Selection -->
                            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-padding: 20;" prefWidth="320">
                                <Label text="👤 CUSTOMER DETAILS"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f3b5c; -fx-border-color: #bae6fd; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 8 0;"/>
                                <GridPane hgap="12" vgap="12">
                                    <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                                    <TextField fx:id="customerNameField" promptText="Customer name" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                                    <Label text="Contact:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                                    <TextField fx:id="customerContactField" promptText="Phone number" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                                    <Label text="Address:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                                    <TextArea fx:id="customerAddressField" promptText="Billing address" prefHeight="60" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                              style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                                </GridPane>

                                <Separator style="-fx-background-color: #e2e8f0;"/>

                                <Label text="💊 ADD ITEMS"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f3b5c; -fx-border-color: #bae6fd; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 8 0;"/>
                                <GridPane hgap="12" vgap="12">
                                    <Label text="Medicine:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                                    <ComboBox fx:id="medicineComboBox" promptText="Select medicine" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                              style="-fx-background-radius: 8; -fx-padding: 4; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                                    <Label text="Quantity:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                                    <TextField fx:id="quantityField" promptText="Qty" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;"/>
                                    <Label text="Unit Price:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e66;"/>
                                    <TextField fx:id="unitPriceField" promptText="Auto-filled" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                               style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-color: #f1f5f9;"/>
                                </GridPane>
                                <Button text="➕ ADD TO CART" onAction="#addToCart"
                                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 8 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);"/>
                            </VBox>

                            <!-- Right: Cart Table -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="🛒 CURRENT CART"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f; -fx-padding: 0 0 5 0;"/>
                                <TableView fx:id="cartTable"
                                           style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 2;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="medicineNameColumn" text="Medicine" prefWidth="200"/>
                                        <TableColumn fx:id="qtyColumn" text="Quantity" prefWidth="80"/>
                                        <TableColumn fx:id="unitPriceColumn" text="Unit Price" prefWidth="100"/>
                                        <TableColumn fx:id="totalColumn" text="Total" prefWidth="100"/>
                                        <TableColumn fx:id="actionColumn" text="Action" prefWidth="80"/>
                                    </columns>
                                    <style>
                                        .table-row-cell:odd {
                                        -fx-background-color: #f1f5f9;
                                        }
                                        .table-row-cell:even {
                                        -fx-background-color: white;
                                        }
                                        .table-row-cell:hover {
                                        -fx-background-color: #e0f2fe;
                                        }
                                        .table-view .column-header {
                                        -fx-background-color: #eef2ff;
                                        -fx-font-weight: bold;
                                        -fx-border-color: #cbd5e1;
                                        -fx-border-width: 0 0 1 0;
                                        }
                                    </style>
                                </TableView>

                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="🗑️ REMOVE SELECTED" onAction="#removeFromCart"
                                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 12; -fx-cursor: hand;"/>
                                    <Button text="🧹 CLEAR CART" onAction="#clearCart"
                                            style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 12; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- Bottom: Totals & Actions -->
                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                            <VBox alignment="CENTER_RIGHT">
                                <Label text="Subtotal:" style="-fx-font-size: 14px; -fx-text-fill: #2c3e66;"/>
                                <Label fx:id="subtotalLabel" text="Rs 0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
                                <Label text="Tax (5%):" style="-fx-font-size: 14px; -fx-text-fill: #2c3e66; -fx-padding: 5 0 0 0;"/>
                                <Label fx:id="taxLabel" text="Rs 0.00" style="-fx-font-size: 14px; -fx-text-fill: #2c3e66;"/>
                                <Label text="Total:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e66; -fx-padding: 8 0 0 0;"/>
                                <Label fx:id="totalLabel" text="Rs 0.00" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                            </VBox>
                            <Button text="🧾 GENERATE INVOICE" onAction="#generateInvoice"
                                    style="-fx-background-color: #0891b2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 12 24; -fx-font-size: 16px; -fx-cursor: hand;"/>
                            <Button text="🖨️ PRINT INVOICE" onAction="#printInvoice"
                                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 12 24; -fx-font-size: 16px; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </Tab>

                <!-- Tab 2: Sales History -->
                <Tab text="📜 SALES HISTORY" closable="false">
                    <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: transparent;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="searchHistoryField" promptText="Search by invoice ID or customer"
                                       style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" HBox.hgrow="ALWAYS"/>
                            <Button text="🔍 SEARCH" onAction="#searchSalesHistory"
                                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                            <Button text="🔄 REFRESH" onAction="#refreshSalesHistory"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                        </HBox>
                        <TableView fx:id="salesHistoryTable"
                                   style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 2;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="invoiceIdColumn" text="Invoice ID" prefWidth="100"/>
                                <TableColumn fx:id="dateColumn" text="Date" prefWidth="130"/>
                                <TableColumn fx:id="customerColumn" text="Customer Name" prefWidth="180"/>
                                <TableColumn fx:id="totalAmountColumn" text="Total Amount" prefWidth="120"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                            </columns>
                            <style>
                                .table-row-cell:odd {
                                -fx-background-color: #f1f5f9;
                                }
                                .table-row-cell:even {
                                -fx-background-color: white;
                                }
                                .table-row-cell:hover {
                                -fx-background-color: #e0f2fe;
                                }
                                .table-view .column-header {
                                -fx-background-color: #eef2ff;
                                -fx-font-weight: bold;
                                -fx-border-color: #cbd5e1;
                                -fx-border-width: 0 0 1 0;
                                }
                            </style>
                        </TableView>
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="📄 VIEW DETAILS" onAction="#viewInvoiceDetails"
                                    style="-fx-background-color: #0891b2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                            <Button text="🖨️ REPRINT INVOICE" onAction="#reprintInvoice"
                                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </Tab>
            </TabPane>
        </center>

        <!-- ==================== BOTTOM STATUS ==================== -->
        <bottom>
            <HBox style="-fx-background-color: #eef2ff; -fx-padding: 8 20; -fx-border-radius: 12; -fx-background-radius: 12;" spacing="15" alignment="CENTER_LEFT">
                <Label text="✅ Ready" style="-fx-text-fill: #1e4620; -fx-font-size: 12px;"/>
                <Label text="💡 Double-click cart item to edit" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="🔄 Tax rate: 5% (configurable)" style="-fx-text-fill: #2c3e66; -fx-font-size: 11px;"/>
            </HBox>
        </bottom>
    </BorderPane>
</AnchorPane>